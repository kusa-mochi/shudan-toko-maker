@startuml
left to right direction
skinparam componentStyle rectangle
skinparam shadowing false
skinparam packageStyle rectangle
skinparam defaultTextAlignment center

package "app/" {
  component "RootLayout\napp/layout.tsx" as RootLayout <<Function Component>>
  component "Home\napp/page.tsx" as Home <<Function Component>>
}

package "app/components/" {
  component "PlannerClientShell" as PlannerClientShell <<Function Component>>
  component "PlannerApp" as PlannerApp <<Function Component>>
  component "PlannerProvider" as PlannerProvider <<Function Component>>
  component "PlannerHero" as PlannerHero <<Function Component>>
  component "HouseholdFormSection" as HouseholdFormSection <<Function Component>>
  component "HouseholdEditorCard" as HouseholdEditorCard <<Function Component>>
  component "HouseholdPreviewPanel" as HouseholdPreviewPanel <<Function Component>>
  component "PairRulesPanel" as PairRulesPanel <<Function Component>>
  component "SchoolEventsPanel" as SchoolEventsPanel <<Function Component>>
  component "FlagDutySettingsPanel" as FlagDutySettingsPanel <<Function Component>>
  component "GroupPlanPanel" as GroupPlanPanel <<Function Component>>
  component "FlagDutyPlanPanel" as FlagDutyPlanPanel <<Function Component>>
}

Home --> PlannerClientShell : renders
PlannerClientShell ..> PlannerApp : dynamic import\nand renders
PlannerApp --> PlannerProvider : wraps with provider
PlannerApp --> PlannerHero : renders
PlannerApp --> HouseholdFormSection : renders
PlannerApp --> HouseholdPreviewPanel : renders
PlannerApp --> PairRulesPanel : renders
PlannerApp --> SchoolEventsPanel : renders
PlannerApp --> FlagDutySettingsPanel : renders
PlannerApp --> GroupPlanPanel : renders
PlannerApp --> FlagDutyPlanPanel : renders
HouseholdFormSection --> HouseholdEditorCard : renders list items

note bottom of RootLayout
  Next.js App Router root layout.
  It is part of the route tree,
  but it does not explicitly import
  other function components in app/.
end note

@enduml